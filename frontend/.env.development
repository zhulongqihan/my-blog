# 开发环境配置

# API 基础地址
VITE_API_BASE_URL=http://localhost:8080

# 应用标题
VITE_APP_TITLE=个人博客 - 开发环境

# 是否启用调试模式
VITE_DEBUG=true

# 日志级别
VITE_LOG_LEVEL=debug

# AI 助手配置（通义千问 DashScope OpenAI 兼容接口）
VITE_AI_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VITE_AI_API_KEY=your-dashscope-api-key-here
VITE_AI_MODEL=qwen-plus
